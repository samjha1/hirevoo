APP_NAME=Hirevo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://hirevo.example.com

# Use database sessions (recommended; avoids 419 on multi-server setups)
SESSION_DRIVER=database
SESSION_CONNECTION=mysql
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=null
# Subdirectory installs (e.g. /hirevo/public): auto-derived from APP_URL if unset
# SESSION_PATH=/hirevo/public

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hirevo
DB_USERNAME=
DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# Job openings keyword search (Elasticsearch — fuzzy + any-word match)
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_HOSTS=http://127.0.0.1:9200
ELASTICSEARCH_JOB_INDEX=hirevo_job_openings
ELASTICSEARCH_SEARCH_LIMIT=500
ELASTICSEARCH_TALENT_POOL_INDEX=hirevo_talent_pool
ELASTICSEARCH_TALENT_POOL_SEARCH_LIMIT=250

# Leadsmanager sponsored ads (public URL, no trailing slash)
LEADSMANAGER_URL=https://ads.example.com
LEADSMANAGER_ADS_ENABLED=true

# Optional: force asset URLs when behind a subdirectory or CDN
# ASSET_URL=https://hirevo.example.com

# Resume AI (OpenRouter and/or OpenAI)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-20b:free
OPENROUTER_SKIP_FREE_WHEN_OPENAI=false
OPENROUTER_HTTP_REFERER=
# openai_api_key_main=   # or OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4-mini

# AWS Bedrock (optional alternative LLM)
# BEDROCK_USE_IAM=true
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_ID=amazon.nova-2-lite-v1:0
# BEDROCK_ALLOW_DEFAULT_CREDENTIAL_CHAIN=false

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI defaults to APP_URL/auth/google/callback

# Microsoft / Azure OAuth (optional)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common
# AZURE_REDIRECT_URI defaults to APP_URL/auth/microsoft/callback

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# SEO (optional overrides)
# SEO_SITE_NAME=Hirevo
# SEO_ORG_NAME=Hirevo
# SEO_ORG_URL=
# SEO_CONTACT_EMAIL=
# SEO_TWITTER_HANDLE=
# SEO_SITEMAP_CACHE_MINUTES=60

# Employer plan checkout (cheque now; set gateway when integrated)
PLAN_CHECKOUT_MODE=cheque
PLAN_GST_RATE=18

# App tuning (optional)
# RESUME_ANALYSIS_TIME_LIMIT=180
# NOTIFICATION_RETENTION_DAYS=14
# LLM_HTTP_TIMEOUT=120
