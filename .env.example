APP_NAME=Hirevo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://hirevo.example.com

# Use database sessions (recommended; avoids 419 on multi-server setups)
SESSION_DRIVER=database
SESSION_CONNECTION=mysql
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=null
# Subdirectory installs (e.g. /hirevo/public): auto-derived from APP_URL if unset
# SESSION_PATH=/hirevo/public

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hirevo
DB_USERNAME=
DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=s3

# S3 file storage (resumes, profile photos)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
# AWS_URL=   # optional CloudFront or custom domain
AWS_USE_PATH_STYLE_ENDPOINT=false
# Private bucket: generate presigned URLs for images/resumes in the browser (default true)
AWS_S3_USE_SIGNED_URLS=true
AWS_S3_SIGNED_URL_MINUTES=1440

# Talent pool search cache (seconds) — speeds repeat searches; no Elasticsearch required
TALENT_POOL_SEARCH_CACHE_TTL=600
TALENT_POOL_SEARCH_CACHE_PAGES=true

# Optional: Elasticsearch / AWS OpenSearch (only if you add it later)
# ELASTICSEARCH_ENABLED=true
# ELASTICSEARCH_HOSTS=https://your-opensearch-endpoint.ap-south-1.es.amazonaws.com:443

# Leadsmanager sponsored ads (public URL, no trailing slash)
LEADSMANAGER_URL=https://ads.example.com
LEADSMANAGER_ADS_ENABLED=true

# Optional: force asset URLs when behind a subdirectory or CDN
# ASSET_URL=https://hirevo.example.com

# Resume AI (OpenRouter and/or OpenAI)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MODEL_FALLBACK=openai/gpt-oss-20b:free
OPENROUTER_SKIP_FREE_WHEN_OPENAI=false
OPENROUTER_HTTP_REFERER=
# openai_api_key_main=   # or OPENAI_API_KEY=
# OpenAI API slug (not display name): gpt-5-mini, gpt-5.4-mini, gpt-5.4-nano
OPENAI_MODEL=gpt-5-mini
# Token / cost tuning (optional — defaults are already conservative)
# LLM_DEFAULT_MAX_TOKENS=400
# LLM_RESUME_BUNDLE_MAX_TOKENS=1200
# LLM_PROFILE_EXTRACT_MAX_TOKENS=2500
# LLM_RESUME_INPUT_MAX_CHARS=5000
# LLM_JOB_DESCRIPTION_MAX_TOKENS=600
# LLM_JOB_RANK_MAX_TOKENS=1200

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI defaults to APP_URL/auth/google/callback

# Microsoft / Azure OAuth (optional)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common
# AZURE_REDIRECT_URI defaults to APP_URL/auth/microsoft/callback

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# SEO (optional overrides)
# SEO_SITE_NAME=Hirevo
# SEO_ORG_NAME=Hirevo
# SEO_ORG_URL=
# SEO_CONTACT_EMAIL=
# SEO_TWITTER_HANDLE=
# SEO_SITEMAP_CACHE_MINUTES=60

# Employer plan checkout (cheque now; set gateway when integrated)
PLAN_CHECKOUT_MODE=razorpay
PLAN_GST_RATE=18

# Razorpay (candidate premium checkout — never expose KEY_SECRET to frontend)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# App tuning (optional)
# RESUME_ANALYSIS_TIME_LIMIT=180
# NOTIFICATION_RETENTION_DAYS=14
# LLM_HTTP_TIMEOUT=120
